    <Grid x:Name="MainGrid" SizeChanged="MainGrid_SizeChanged">
        <Grid.RowDefinitions>
            <RowDefinition Height="578" />
            <RowDefinition Height="5"/>
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="958" />
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Browser 1 -->
        <Grid Grid.Row="0" Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="2">
                <Button Content="Go"
                    Width="45"
                    DockPanel.Dock="Right"
                    Click="GoButton_Click"
                    Tag="1"/>

                <TextBox x:Name="AddressBar1"
                     Margin="0,0,2,0"
                     KeyDown="AddressBar_KeyDown"/>
            </DockPanel>

            <Wpf:WebView2 x:Name="wb1"
                      Grid.Row="1"/>
        </Grid>

        <!-- Browser 2 -->
        <Grid Grid.Row="0" Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="2">
                <Button Content="Go"
                    Width="45"
                    DockPanel.Dock="Right"
                    Click="GoButton_Click"
                    Tag="2"/>

                <TextBox x:Name="AddressBar2"
                     Margin="0,0,2,0"
                     KeyDown="AddressBar_KeyDown"/>
            </DockPanel>

            <Wpf:WebView2 x:Name="wb2"
                      Grid.Row="1"/>
        </Grid>

        <!-- Browser 3 -->
        <Grid Grid.Row="2" Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="2">
                <Button Content="Go"
                    Width="45"
                    DockPanel.Dock="Right"
                    Click="GoButton_Click"
                    Tag="3"/>

                <TextBox x:Name="AddressBar3"
                     Margin="0,0,2,0"
                     KeyDown="AddressBar_KeyDown"/>
            </DockPanel>

            <Wpf:WebView2 x:Name="wb3"
                      Grid.Row="1"/>
        </Grid>

        <!-- Browser 4 -->
        <Grid Grid.Row="2" Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="2">
                <Button Content="Go"
                    Width="45"
                    DockPanel.Dock="Right"
                    Click="GoButton_Click"
                    Tag="4"/>

                <TextBox x:Name="AddressBar4"
                     Margin="0,0,2,0"
                     KeyDown="AddressBar_KeyDown"/>
            </DockPanel>

            <Wpf:WebView2 x:Name="wb4"
                      Grid.Row="1"/>
        </Grid>

        <!-- Vertical splitter -->
        <GridSplitter
        Grid.Row="0"
        Grid.RowSpan="3"
        Grid.Column="1"
        Width="5"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch"
        ResizeBehavior="PreviousAndNext"
        ResizeDirection="Columns"
        Background="Gray"/>

        <!-- Horizontal splitter -->
        <GridSplitter
        Grid.Row="1"
        Grid.Column="0"
        Grid.ColumnSpan="3"
        Height="5"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch"
        ResizeBehavior="PreviousAndNext"
        ResizeDirection="Rows"
        Background="Gray"/>
    </Grid>
</Window>
